# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
# STRIPE_MODE defaults to TEST when unset. Live billing requires an explicit
# STRIPE_MODE=live opt-in, so a fresh deploy can never take a real payment
# before you've set and tested your env vars.
STRIPE_MODE=test
STRIPE_SECRET_KEY=your_stripe_live_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_live_webhook_secret
# Monthly price IDs, forked by account type (annual retired):
#   Golf Club    → £99/month
#   County Union → £199/month
STRIPE_CLUB_PRICE_ID=your_stripe_live_club_price_id
STRIPE_COUNTY_PRICE_ID=your_stripe_live_county_price_id

# Test mode Stripe keys (used when STRIPE_MODE=test)
TEST_STRIPE_SECRET_KEY=your_stripe_test_secret_key
TEST_STRIPE_WEBHOOK_SECRET=your_stripe_test_webhook_secret
TEST_STRIPE_CLUB_PRICE_ID=your_stripe_test_club_price_id
TEST_STRIPE_COUNTY_PRICE_ID=your_stripe_test_county_price_id

# Resend
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@countyconsent.uk
ADMIN_EMAIL=hello@pinhighmedia.uk

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_LOGIN_URL=https://countyconsent.uk
