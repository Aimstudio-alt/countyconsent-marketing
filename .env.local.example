# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
# Set STRIPE_MODE=test to use test keys, or omit/set to live for production
STRIPE_MODE=live
STRIPE_SECRET_KEY=your_stripe_live_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_live_webhook_secret
STRIPE_MONTHLY_PRICE_ID=your_stripe_live_monthly_price_id
STRIPE_ANNUAL_PRICE_ID=your_stripe_live_annual_price_id

# Test mode Stripe keys (used when STRIPE_MODE=test)
TEST_STRIPE_SECRET_KEY=your_stripe_test_secret_key
TEST_STRIPE_MONTHLY_PRICE_ID=your_stripe_test_monthly_price_id
TEST_STRIPE_ANNUAL_PRICE_ID=your_stripe_test_annual_price_id

# Resend
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@countyconsent.co.uk
ADMIN_EMAIL=hello@pinhighmedia.uk

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_LOGIN_URL=https://app.countyconsent.co.uk
